# Proxy-only Dockerfile
FROM node:18-alpine

RUN apk add --no-cache git curl

WORKDIR /app

# Copy package files and install dependencies
COPY proxy/package*.json ./
RUN npm ci --only=production

# Copy proxy source
COPY proxy/server.js proxy/cards.js ./

ENV DATA_DIR=/data

# Expose port
EXPOSE 2426

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:2426/health || exit 1

CMD ["node", "server.js"]
