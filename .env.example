# ============================================
# SillyTavern Character Generator Configuration
# ============================================
# Copy this file to .env and customize the values

# Port for the frontend web interface (default: 2427)
FRONTEND_PORT=2427

# Port for the backend proxy server (default: 2426)
PROXY_PORT=2426

# Frontend URL for CORS and API headers (auto-generated if not set)
# FRONTEND_URL=http://localhost:2427

# Directory where card data (card.json files + git repo) is stored.
# Defaults to /data in Docker. Override to use a bind-mount path instead of a named volume:
#   DATA_DIR=/host/path/to/cards
# DATA_DIR=/data

# Git author identity for card version commits (Docker / server mode)
# GIT_AUTHOR_NAME=Character Generator
# GIT_AUTHOR_EMAIL=cards@character-generator.local
