# ============================================
# SillyTavern Character Generator Configuration
# ============================================
# Copy this file to .env and customize the values

# Port the app listens on (default: 2426)
PORT=2426

# Directory where card and prompt data (json files + git repo) is stored.
# Defaults to /data in Docker. Override to use a bind-mount path:
#   DATA_DIR=/host/path/to/data
# DATA_DIR=/data

# Git author identity for version history commits
# GIT_AUTHOR_NAME=Character Generator
# GIT_AUTHOR_EMAIL=cards@character-generator.local
