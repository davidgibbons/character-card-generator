{
  "name": "sillytavern-character-generator",
  "version": "1.0.0",
  "description": "A web app for generating SillyTavern character cards with AI",
  "main": "index.html",
  "scripts": {
    "dev": "concurrently \"npm run dev:proxy\" \"npm run dev:frontend\"",
    "dev:proxy": "cd proxy && npx nodemon server.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cd proxy && node server.js"
  },
  "keywords": [
    "sillytavern",
    "character-generator",
    "ai",
    "character-cards",
    "web-app"
  ],
  "author": "Character Generator App",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/character-generator.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/character-generator/issues"
  },
  "homepage": "https://github.com/yourusername/character-generator#readme",
  "dependencies": {
    "diff": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tributejs": "^5.1.3",
    "zustand": "^5.0.12"
  }
}
